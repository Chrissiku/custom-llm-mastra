# OpenAI-compatible API (used by MyPrivateGateway).
# Must be the base URL *before* /chat/completions (AI SDK appends /chat/completions).
# Example: POST http://localhost:3000/api/chat/completions → CUSTOM_URL=http://localhost:3000/api
CUSTOM_URL=http://localhost:3000/api
CUSTOM_API_KEY=your-api-key-or-token

# Set to true only if your server supports OpenAI stream_options.include_usage (many local APIs do not).
# CUSTOM_OPENAI_INCLUDE_USAGE=true

# Optional: Mastra dev mode generates gateway model ID autocomplete (~/.cache/mastra/)
# MASTRA_DEV=true
